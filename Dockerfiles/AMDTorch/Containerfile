# AMD's official PyTorch ROCm image
FROM docker.io/rocm/pytorch:latest

# Set your working directory
WORKDIR $TMP_DIR

# ROCm-specific torch
RUN pip install --no-cache-dir torch torchvision --index-url https://download.pytorch.org

# Docling and Surya
RUN pip install --no-cache-dir docling docling-surya

# Keep the container open with a bash shell
CMD ["/bin/bash"]
